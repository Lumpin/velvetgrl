---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="max-w-3xl mx-auto px-4 py-20 text-center">
    <h1 class="font-display text-5xl font-bold text-brand-dark mb-4">404</h1>
    <p class="text-xl text-brand-muted mb-8">Oops — this page doesn't exist.</p>
    <a
      href="/"
      class="inline-block px-6 py-3 bg-brand-sage text-white rounded-full hover:bg-brand-sage/80 transition-colors mb-16"
    >
      Back to Home
    </a>

    <h2 class="font-display text-2xl font-semibold text-brand-dark mb-6">You might like these instead</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 text-left">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}/`}
          class="block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow group"
        >
          {post.data.featured_image && (
            <img
              src={post.data.featured_image}
              alt={post.data.title}
              class="w-full h-36 object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          )}
          <div class="p-4">
            <h3 class="font-display text-sm font-semibold group-hover:text-brand-sage transition-colors">
              {post.data.title}
            </h3>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
